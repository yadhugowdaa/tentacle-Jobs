# Copy this file to ".env" and fill in values. ".env" is gitignored.

# --- LLM provider (the "brain": tailoring, screening answers, profile extraction) ---
# Choose one: "gemini" (https://aistudio.google.com/apikey) or "nvidia" (https://build.nvidia.com).
LLM_PROVIDER=nvidia

# Google Gemini.
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash-lite

# NVIDIA NIM (free developer tier). Single endpoint used when NVIDIA_POOL is empty.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Optional rotation pool: each LLM call round-robins across these (key, model) pairs and fails
# over on rate-limit/error, multiplying free-tier throughput. JSON array on one line:
# NVIDIA_POOL=[{"key":"nvapi-...","model":"meta/llama-3.3-70b-instruct"}, ...]
NVIDIA_POOL=[]

# Requests/sec throttle. With a multi-key pool each key sees rate/N, so this can be higher.
LLM_RPS=1.0

# --- Database (SQLite by default; set to a Postgres URL when hosting) ---
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=

# --- Matching / embeddings (local, free) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Defaults ---
DEFAULT_TARGET_APPLICATIONS=20

# --- Logging (DEBUG | INFO | WARNING | ERROR) ---
LOG_LEVEL=INFO
